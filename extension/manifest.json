{
  "manifest_version": 3,
  "key": "",
  "name": "Hemingweight",
  "description": "Browser-based coding environment powered by AI. Describe what you want in plain English and watch it get built.",
  "version": "1.5.10",
  "author": "Alexandre Flamant",
  "homepage_url": "https://hemingweight.vercel.app",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel", "nativeMessaging"],
  "action": {
    "default_title": "Open Hemingweight",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
